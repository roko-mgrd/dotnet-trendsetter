{
  "name": "trendsetter",
  "displayName": "Trendsetter",
  "description": "View, run, and analyze Trendsetter AI trend tests",
  "version": "0.1.0",
  "publisher": "roko-labs",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [
    "onView:trendsetterTests",
    "workspaceContains:**/Trendsetter.Engine.csproj"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "trendsetter",
          "title": "Trendsetter",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "trendsetter": [
        {
          "id": "trendsetterTests",
          "name": "Trend Tests"
        }
      ]
    },
    "commands": [
      {
        "command": "trendsetter.refresh",
        "title": "Refresh",
        "category": "Trendsetter",
        "icon": "$(refresh)"
      },
      {
        "command": "trendsetter.runAllTests",
        "title": "Run All Tests",
        "category": "Trendsetter",
        "icon": "$(run-all)"
      },
      {
        "command": "trendsetter.openDashboard",
        "title": "Open Dashboard",
        "category": "Trendsetter",
        "icon": "$(dashboard)"
      },
      {
        "command": "trendsetter.generateDashboard",
        "title": "Generate Dashboard",
        "category": "Trendsetter",
        "icon": "$(file-code)"
      },
      {
        "command": "trendsetter.openReport",
        "title": "Open Report",
        "category": "Trendsetter",
        "icon": "$(open-preview)"
      },
      {
        "command": "trendsetter.generateReport",
        "title": "Generate Report",
        "category": "Trendsetter",
        "icon": "$(file-code)"
      },
      {
        "command": "trendsetter.showRunDetails",
        "title": "Show Run Details",
        "category": "Trendsetter"
      },
      {
        "command": "trendsetter.runTest",
        "title": "Run Test",
        "category": "Trendsetter",
        "icon": "$(play)"
      },
      {
        "command": "trendsetter.stopTest",
        "title": "Stop Test",
        "category": "Trendsetter",
        "icon": "$(debug-stop)"
      },
      {
        "command": "trendsetter.stopAllTests",
        "title": "Stop All Tests",
        "category": "Trendsetter",
        "icon": "$(debug-stop)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "trendsetter.runAllTests",
          "when": "view == trendsetterTests && !trendsetter.anyRunning",
          "group": "navigation@1"
        },
        {
          "command": "trendsetter.stopAllTests",
          "when": "view == trendsetterTests && trendsetter.anyRunning",
          "group": "navigation@1"
        },
        {
          "command": "trendsetter.openDashboard",
          "when": "view == trendsetterTests",
          "group": "navigation@2"
        },
        {
          "command": "trendsetter.refresh",
          "when": "view == trendsetterTests",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "trendsetter.runTest",
          "when": "view == trendsetterTests && viewItem == trend",
          "group": "inline@1"
        },
        {
          "command": "trendsetter.stopTest",
          "when": "view == trendsetterTests && viewItem == trendRunning",
          "group": "inline@1"
        },
        {
          "command": "trendsetter.openReport",
          "when": "view == trendsetterTests && viewItem =~ /^trend(Running)?$/",
          "group": "inline@2"
        },
        {
          "command": "trendsetter.generateReport",
          "when": "view == trendsetterTests && viewItem =~ /^trend(Running)?$/",
          "group": "context@1"
        }
      ]
    },
    "configuration": {
      "title": "Trendsetter"
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package",
    "install-ext": "npx @vscode/vsce package && code --install-extension trendsetter-0.1.0.vsix"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
